{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/stay-drafts/[id]/run-import/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "app/api/internal/stay-import-worker/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "app/api/cron/stay-import-worker/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "app/api/import-stay/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/stay-import-worker",
      "schedule": "*/2 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.resacolo.com"
        }
      ],
      "destination": "https://resacolo.com/:path*",
      "statusCode": 308
    }
  ]
}
